{
  "name": "kiraude",
  "version": "0.1.4",
  "description": "Run Claude Code powered by Kiro CLI — one command, zero config",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kiraude": "dist/bin/kiraude.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "release": "bash scripts/release.sh"
  },
  "keywords": [
    "claude",
    "claude-code",
    "kiro",
    "kiro-cli",
    "anthropic",
    "proxy",
    "acp",
    "cli",
    "ai",
    "llm"
  ],
  "author": "Sabeur Hengawi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thabti/kiraude-code.git"
  },
  "homepage": "https://github.com/thabti/kiraude-code#readme",
  "bugs": {
    "url": "https://github.com/thabti/kiraude-code/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "express": "^4.21.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pino-http": "^5.8.4",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
